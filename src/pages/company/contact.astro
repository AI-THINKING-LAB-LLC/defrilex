---
import { ArrowRight, Building2, Check, Clock, Facebook, Globe, Headphones, Linkedin, Mail, Shield, Twitter, Users } from "lucide-react";
import Footer from "../../components/Footer.astro";
import Navigation from "../../components/navigation";
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/page-header.astro";
import ContactLocation from "../../components/contact-location";

const capabilities = [
{ label: "Languages", value: "300+ languages and dialects" },
{ label: "Coverage", value: "Operations spanning multiple continents" },
{ label: "Compliance", value: "GDPR, HIPAA, PCI-DSS certified" },
{ label: "Availability", value: "24/7/365 support" },
{ label: "Team", value: "20000+ trained professionals" },
{ label: "Clients", value: "100+ businesses worldwide" }];


const industries = [
"Healthcare providers needing HIPAA-compliant interpretation services",
"Legal firms requiring certified translation and interpretation",
"Government agencies with multilingual communication needs",
"Businesses expanding into global markets"];


const processSteps = [
"You reach out with your challenge or requirements",
"We respond within 24 hours (usually much faster)",
"We assess your needs and propose a solution that actually fits your business",
"We deliver results with the quality and compliance your industry demands"
];
---
  <Layout>
    <main class="min-h-screen ">
    <Navigation client:load/>
    
    <PageHeader 
      heading="Contact" 
      title='Get In Touch'
      image="https://images.unsplash.com/photo-1615840287214-7ff58936c4cf?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      description="Whether you need multilingual BPO services, healthcare interpretation, legal translation, or 24/7 customer support across borders—let's talk about how Defrilex can help."
      buttons={[
        {
          link: '#contact-us',
          name: 'Contact us'
        }
      ]}
      />
  
    <section class="py-[80px] md:py-[100px] px-6 bg-white" id="contact-us">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
          <div>
            <h2 class="text-[32px] md:text-[40px] font-bold text-[#1A1A1A] leading-[1.1] tracking-[-0.02em] mb-8">
              Our Global Network
            </h2>
            
            <div class="space-y-8">
              <div class="flex gap-5">
                <div class="w-14 h-14 rounded-2xl bg-[#00003d]/10 flex items-center justify-center flex-shrink-0">
                  <Building2 className="w-7 h-7 text-[#00003d]" />
                </div>
                <div>
                  <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">Headquarters</h3>
                  <p class="text-[16px] text-[#4A4A4A]">Miami, Florida, USA</p>
                </div>
              </div>
              
              <div class="flex gap-5">
                <div class="w-14 h-14 rounded-2xl bg-[#00003d]/10 flex items-center justify-center flex-shrink-0">
                  <Globe className="w-7 h-7 text-[#00003d]" />
                </div>
                <div>
                  <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">Operational Reach</h3>
                  <ul class="space-y-2 text-[16px] text-[#4A4A4A]">
                    <li>55+ countries served</li>
                    <li class="!whitespace-pre-line">300+ languages covered</li>
                    <li>24/7 availability across all time zones</li>
                  </ul>
                </div>
              </div>
            </div>
            
            <p class="mt-8 text-[16px] text-[#4A4A4A] leading-[1.8] border-l-4 border-[#ef9c31] pl-6">
              We maintain a distributed network of trained, certified professionals who deliver services where and when your business needs them—from major cities to remote locations.
            </p>
          </div>
          
          <div class="bg-[#FAFAFA] rounded-3xl p-8 md:p-10">
            <h3 class="text-[24px] font-bold text-[#1A1A1A] mb-6">Who We Serve</h3>
            <ul class="space-y-4">
              {industries.map((industry, index) =>
              <li  class="flex gap-4 items-start">
                  <div class="w-6 h-6 rounded-full bg-[#00003d] flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Check className="w-3.5 h-3.5 text-white" />
                  </div>
                  <span class="text-[15px] text-[#4A4A4A] leading-[1.7]">{industry}</span>
                </li>
              )}
            </ul>
            <p class="mt-6 text-[15px] text-[#6B7280] leading-[1.7] italic">
              If your industry demands compliance, accuracy, and reliability—we've built our operations to deliver exactly that.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactLocation client:load/>

    <section class="py-[80px] md:py-[100px] px-6 bg-[#FAFAFA]">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="text-[32px] md:text-[40px] font-bold text-[#1A1A1A] leading-[1.1] tracking-[-0.02em] mb-12 text-center">
          Connect With Our Team
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white rounded-2xl p-8 border border-[#E5E5E5] hover:shadow-xl transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00003d]/10 flex items-center justify-center mb-5">
              <Mail className="w-6 h-6 text-[#00003d]" />
            </div>
            <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">General Inquiries</h3>
            <p class="text-[14px] text-[#6B7280] mb-4">For questions and information</p>
            <a href="mailto:info@defrilex.com" class="text-[15px] text-[#00003d] font-semibold hover:text-[#ef9c31] transition-colors">
              info@defrilex.com
            </a>
          </div>
          
          <div class="bg-white rounded-2xl p-8 border border-[#E5E5E5] hover:shadow-xl transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#ef9c31]/10 flex items-center justify-center mb-5">
              <Users className="w-6 h-6 text-[#ef9c31]" />
            </div>
            <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">Sales & Partnerships</h3>
            <p class="text-[14px] text-[#6B7280] mb-4">Talk to our Chief Revenue Officer</p>
            <a href="mailto:sales@defrilex.com" class="inline-flex items-center gap-2 text-[15px] text-[#00003d] font-semibold hover:text-[#ef9c31] transition-colors">
              Contact Sales
              <ArrowRight className="w-4 h-4" />
            </a>
          </div>
          
          <div class="bg-white rounded-2xl p-8 border border-[#E5E5E5] hover:shadow-xl transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#3B82F6]/10 flex items-center justify-center mb-5">
              <Headphones className="w-6 h-6 text-[#3B82F6]" />
            </div>
            <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">Client Support</h3>
            <p class="text-[14px] text-[#6B7280] mb-4">24/7 support for existing clients</p>
            <a href="tel:+1-800-DEFRILEX" class="text-[15px] text-[#00003d] font-semibold hover:text-[#ef9c31] transition-colors">
              1-800-DEFRILEX
            </a>
          </div>
          
          <div class="bg-white rounded-2xl p-8 border border-[#E5E5E5] hover:shadow-xl transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#10B981]/10 flex items-center justify-center mb-5">
              <Shield className="w-6 h-6 text-[#10B981]" />
            </div>
            <h3 class="text-[18px] font-bold text-[#1A1A1A] mb-2">Leadership Contact</h3>
            <p class="text-[14px] text-[#6B7280] mb-4">Fritz Gerald Zephirin, CEO</p>
            <a href="mailto:ceo@defrilex.com" class="text-[15px] text-[#00003d] font-semibold hover:text-[#ef9c31] transition-colors !whitespace-pre-line">team@defrilex.com

            </a>
          </div>
        </div>
      </div>
    </section>


   


    <div class="grid lg:grid-cols-2 items-start gap-16 p-6 mx-auto max-w-5xl max-lg:max-w-3xl py-14 md:py-24 bg-white">
      <div>
        <h2 class="text-slate-900 text-3xl font-bold">Let's Talk</h2>
        <p class="text-[15px] text-slate-600 mt-4 leading-relaxed">Have some big idea or brand to develop and need help? Then reach out we'd love to hear about your project  and provide help.</p>
        <div class="mt-12">
          <h2 class="text-slate-900 text-base font-semibold">Email</h2>
          <ul class="mt-4">
            <li class="flex items-center">
              <div class="bg-[#e6e6e6cf] h-10 w-10 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20px" height="20px" fill='#000'
                  viewBox="0 0 479.058 479.058">
                  <path
                    d="M434.146 59.882H44.912C20.146 59.882 0 80.028 0 104.794v269.47c0 24.766 20.146 44.912 44.912 44.912h389.234c24.766 0 44.912-20.146 44.912-44.912v-269.47c0-24.766-20.146-44.912-44.912-44.912zm0 29.941c2.034 0 3.969.422 5.738 1.159L239.529 264.631 39.173 90.982a14.902 14.902 0 0 1 5.738-1.159zm0 299.411H44.912c-8.26 0-14.971-6.71-14.971-14.971V122.615l199.778 173.141c2.822 2.441 6.316 3.655 9.81 3.655s6.988-1.213 9.81-3.655l199.778-173.141v251.649c-.001 8.26-6.711 14.97-14.971 14.97z"
                    data-original="#000000" />
                </svg>
              </div>
              <a href="mailto:info@defrilex.com" class="text-sm ml-4">
                <small class="block text-slate-900">Mail</small>
                <spane class="font-semibold text-blue-600">info@defrilex.com</spane>
              </a>
            </li>
          </ul>
        </div>

        <div class="mt-12">
          <h2 class="text-slate-900 text-base font-semibold">Socials</h2>
          <ul class="flex mt-4 space-x-4">
            <li class="bg-[#e6e6e6cf] h-10 w-10 rounded-full flex items-center justify-center shrink-0">
              <a href="https://www.facebook.com/defrilex">
                <svg xmlns="http://www.w3.org/2000/svg" width="20px" height="20px" fill='#000'
                  viewBox="0 0 24 24">
                  <path
                    d="M6.812 13.937H9.33v9.312c0 .414.335.75.75.75l4.007.001a.75.75 0 0 0 .75-.75v-9.312h2.387a.75.75 0 0 0 .744-.657l.498-4a.75.75 0 0 0-.744-.843h-2.885c.113-2.471-.435-3.202 1.172-3.202 1.088-.13 2.804.421 2.804-.75V.909a.75.75 0 0 0-.648-.743A26.926 26.926 0 0 0 15.071 0c-7.01 0-5.567 7.772-5.74 8.437H6.812a.75.75 0 0 0-.75.75v4c0 .414.336.75.75.75zm.75-3.999h2.518a.75.75 0 0 0 .75-.75V6.037c0-2.883 1.545-4.536 4.24-4.536.878 0 1.686.043 2.242.087v2.149c-.402.205-3.976-.884-3.976 2.697v2.755c0 .414.336.75.75.75h2.786l-.312 2.5h-2.474a.75.75 0 0 0-.75.75V22.5h-2.505v-9.312a.75.75 0 0 0-.75-.75H7.562z"
                    data-original="#000000" />
                </svg>
              </a>
            </li>
            <li class="bg-[#e6e6e6cf] h-10 w-10 rounded-full flex items-center justify-center shrink-0">
              <a href="javascript:void(0)">
                <svg xmlns="http://www.w3.org/2000/svg" width="20px" height="20px" fill='#000'
                  viewBox="0 0 511 512">
                  <path
                    d="M111.898 160.664H15.5c-8.285 0-15 6.719-15 15V497c0 8.285 6.715 15 15 15h96.398c8.286 0 15-6.715 15-15V175.664c0-8.281-6.714-15-15-15zM96.898 482H30.5V190.664h66.398zM63.703 0C28.852 0 .5 28.352.5 63.195c0 34.852 28.352 63.2 63.203 63.2 34.848 0 63.195-28.352 63.195-63.2C126.898 28.352 98.551 0 63.703 0zm0 96.395c-18.308 0-33.203-14.891-33.203-33.2C30.5 44.891 45.395 30 63.703 30c18.305 0 33.195 14.89 33.195 33.195 0 18.309-14.89 33.2-33.195 33.2zm289.207 62.148c-22.8 0-45.273 5.496-65.398 15.777-.684-7.652-7.11-13.656-14.942-13.656h-96.406c-8.281 0-15 6.719-15 15V497c0 8.285 6.719 15 15 15h96.406c8.285 0 15-6.715 15-15V320.266c0-22.735 18.5-41.23 41.235-41.23 22.734 0 41.226 18.495 41.226 41.23V497c0 8.285 6.719 15 15 15h96.403c8.285 0 15-6.715 15-15V302.066c0-79.14-64.383-143.523-143.524-143.523zM466.434 482h-66.399V320.266c0-39.278-31.953-71.23-71.226-71.23-39.282 0-71.239 31.952-71.239 71.23V482h-66.402V190.664h66.402v11.082c0 5.77 3.309 11.027 8.512 13.524a15.01 15.01 0 0 0 15.875-1.82c20.313-16.294 44.852-24.907 70.953-24.907 62.598 0 113.524 50.926 113.524 113.523zm0 0"
                    data-original="#000000" />
                </svg>
              </a>
            </li>
            <li class="bg-[#e6e6e6cf] h-10 w-10 rounded-full flex items-center justify-center shrink-0">
              <a href="javascript:void(0)">
                <svg xmlns="http://www.w3.org/2000/svg" width="20px" height="20px" fill='#000'
                  viewBox="0 0 24 24">
                  <path
                    d="M12 9.3a2.7 2.7 0 1 0 0 5.4 2.7 2.7 0 0 0 0-5.4Zm0-1.8a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Zm5.85-.225a1.125 1.125 0 1 1-2.25 0 1.125 1.125 0 0 1 2.25 0ZM12 4.8c-2.227 0-2.59.006-3.626.052-.706.034-1.18.128-1.618.299a2.59 2.59 0 0 0-.972.633 2.601 2.601 0 0 0-.634.972c-.17.44-.265.913-.298 1.618C4.805 9.367 4.8 9.714 4.8 12c0 2.227.006 2.59.052 3.626.034.705.128 1.18.298 1.617.153.392.333.674.632.972.303.303.585.484.972.633.445.172.918.267 1.62.3.993.047 1.34.052 3.626.052 2.227 0 2.59-.006 3.626-.052.704-.034 1.178-.128 1.617-.298.39-.152.674-.333.972-.632.304-.303.485-.585.634-.972.171-.444.266-.918.299-1.62.047-.993.052-1.34.052-3.626 0-2.227-.006-2.59-.052-3.626-.034-.704-.128-1.18-.299-1.618a2.619 2.619 0 0 0-.633-.972 2.595 2.595 0 0 0-.972-.634c-.44-.17-.914-.265-1.618-.298-.993-.047-1.34-.052-3.626-.052ZM12 3c2.445 0 2.75.009 3.71.054.958.045 1.61.195 2.185.419A4.388 4.388 0 0 1 19.49 4.51c.457.45.812.994 1.038 1.595.222.573.373 1.227.418 2.185.042.96.054 1.265.054 3.71 0 2.445-.009 2.75-.054 3.71-.045.958-.196 1.61-.419 2.185a4.395 4.395 0 0 1-1.037 1.595 4.44 4.44 0 0 1-1.595 1.038c-.573.222-1.227.373-2.185.418-.96.042-1.265.054-3.71.054-2.445 0-2.75-.009-3.71-.054-.958-.045-1.61-.196-2.185-.419A4.402 4.402 0 0 1 4.51 19.49a4.414 4.414 0 0 1-1.037-1.595c-.224-.573-.374-1.227-.419-2.185C3.012 14.75 3 14.445 3 12c0-2.445.009-2.75.054-3.71s.195-1.61.419-2.185A4.392 4.392 0 0 1 4.51 4.51c.45-.458.994-.812 1.595-1.037.574-.224 1.226-.374 2.185-.419C9.25 3.012 9.555 3 12 3Z">
                  </path>
                </svg>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <form id="contact-form" class="lg:ml-auto space-y-4">
        <input id="contact-name" name="name" type="text" autocomplete="name" placeholder="Name" required
          class="w-full rounded-md py-3 px-4 bg-slate-100 text-slate-900 text-sm border border-gray-200 focus:border-slate-900 outline-none focus:bg-transparent" />
        <input id="contact-email" name="email" type="email" autocomplete="email" placeholder="Email" required
          class="w-full rounded-md py-3 px-4 bg-slate-100 text-slate-900 text-sm border border-gray-200 focus:border-slate-900 outline-none focus:bg-transparent" />
        <input id="contact-subject" name="subject" type="text" placeholder="Subject" required
          class="w-full rounded-md py-3 px-4 bg-slate-100 text-slate-900 text-sm border border-gray-200 focus:border-slate-900 outline-none focus:bg-transparent" />
        <textarea id="contact-message" name="message" placeholder="Message" rows="6" required
          class="w-full rounded-md px-4 bg-slate-100 text-slate-900 text-sm pt-3 border border-gray-200 focus:border-slate-900 outline-none focus:bg-transparent"></textarea>
        <button type="submit"
          class="text-white bg-slate-900 hover:bg-slate-800 tracking-wide rounded-md text-sm font-medium px-4 py-3 w-full cursor-pointer !mt-2 border-0">Send message</button>
      </form>
      <script is:inline>
        (() => {
          const form = document.getElementById("contact-form");
          if (!form) return;

          const TO_EMAIL = "info@defrilex.com";

          const safe = (v) => (typeof v === "string" ? v.trim() : "");

          form.addEventListener("submit", (e) => {
            e.preventDefault();

            const name = safe(document.getElementById("contact-name")?.value);
            const email = safe(document.getElementById("contact-email")?.value);
            const subjectInput = safe(document.getElementById("contact-subject")?.value);
            const message = safe(document.getElementById("contact-message")?.value);

            const subject = subjectInput || "Website contact form";
            const bodyLines = [
              "New website contact form submission",
              "",
              `Name: ${name || "-"}`,
              `Email: ${email || "-"}`,
              "",
              "Message:",
              message || "-"
            ];
            const body = bodyLines.join("\n");

            const gmailUrl =
              "https://mail.google.com/mail/?view=cm&fs=1" +
              `&to=${encodeURIComponent(TO_EMAIL)}` +
              `&su=${encodeURIComponent(subject)}` +
              `&body=${encodeURIComponent(body)}`;

            const mailtoUrl =
              `mailto:${encodeURIComponent(TO_EMAIL)}` +
              `?subject=${encodeURIComponent(subject)}` +
              `&body=${encodeURIComponent(body)}`;

            const newWindow = window.open(gmailUrl, "_blank", "noopener,noreferrer");
            if (!newWindow) window.location.href = mailtoUrl;
          });
        })();
      </script>
    </div>
    <section class="py-[80px] md:py-[100px] px-6 bg-[#FAFAFA]">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="text-[32px] md:text-[40px] font-bold text-[#1A1A1A] leading-[1.1] tracking-[-0.02em] mb-12 text-center">
          Our Capabilities
        </h2>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {capabilities.map((cap, index) =>
          <div class="bg-white rounded-2xl p-6 border border-[#E5E5E5] text-center hover:border-[#00003d]/20 transition-colors">
              <div class="w-10 h-10 rounded-full bg-[#00003d] flex items-center justify-center mx-auto mb-4">
                <Check className="w-5 h-5 text-white" />
              </div>
              <h3 class="text-[14px] font-bold text-[#1A1A1A] mb-2">{cap.label}</h3>
              <p class="text-[13px] text-[#6B7280] leading-[1.5] !whitespace-pre-line !whitespace-pre-line">{cap.value}</p>
            </div>
          )}
        </div>
      </div>
    </section>
    <Footer />
  </main>
  </Layout>