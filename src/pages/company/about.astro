---
import { ArrowRight, Bot, Building2, Clock, DollarSign, Globe, Handshake, Headphones, Heart, Quote, Scale, Shield, Sparkles, Target, TrendingUp, Users } from "lucide-react";
import Footer from "../../components/Footer.astro";
import Navigation from "../../components/navigation";
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/page-header.astro";

const whyWorkWithUs = [
{
  icon: Globe,
  title: "Global Reach, Personal Service",
  description: "55+ countries, 100+ languages, and a network of trained professionals. We cover major cities and remote locations—wherever your business needs communication support."
},
{
  icon: DollarSign,
  title: "Real Cost Efficiency",
  description: "Pay-per-consumption pricing means you're not locked into expensive contracts for capacity you don't use. Scale up when you need us, scale down when you don't. Simple."
},
{
  icon: Handshake,
  title: "Flexible Partnerships",
  description: "We offer multiple contract structures—fixed price, time and material, or custom arrangements. Tell us what works for your business, and we'll make it happen."
},
{
  icon: Users,
  title: "Trained Professionals Who Deliver",
  description: "Our interpreters and agents are certified and vetted. Many work remotely, which gives us flexibility and cost advantages we pass on to you. But whether on-site or remote, they meet the same professional standards."
},
{
  icon: Clock,
  title: "Actual Coverage When You Need It",
  description: "24/7 availability isn't a marketing claim—it's how we operate. Healthcare emergencies don't happen 9-5, legal matters don't wait for business hours, and neither do we."
}];


const timeline = [
{
  year: "2022",
  title: "Foundation",
  description: "Defrilex was founded to solve a real problem: businesses needed reliable multilingual communication, but most providers were either too expensive, too rigid, or too unreliable. We started with healthcare and legal services, building our reputation one satisfied client at a time."
},
{
  year: "2023",
  title: "Building the Network",
  description: "Expanded our interpreter network across countries and languages. Developed training and certification processes. Started serving government clients. Learned what works and what doesn't through actual experience, not theory."
},
{
  year: "2024",
  title: "Growth and Compliance",
  description: "Achieved GDPR, HIPAA, and PCI-DSS compliance. Reached seven-figure revenue. Built out 24/7 operations. Survived COVID by being adaptable and focused on client needs."
},
{
  year: "2025",
  title: "What's Next",
  description: "Integrating smart AI tools with human professionals. Expanding into new markets while staying true to what made us successful: reliability, quality, and treating clients like partners."
},
{
  year: "2026",
  title: "Innovation and Scale",
  description: "Founder launches AI Thinking Lab to explore how AI can enhance (not replace) human expertise in language services. Continue expanding network while maintaining quality standards. Begin ISO 20000 and SOC 2 certification processes."
},
];


const values = [
{
  icon: Target,
  title: "Excellence",
  description: "We pursue the highest standards, delivering quality and consistency in everything we do, and steward our resources wisely."
},
{
  icon: Shield,
  title: "Integrity",
  description: "We act with honesty, transparency, and accountability, staying committed to our mission, our clients, and each other."
},
{
  icon: Heart,
  title: "Respect",
  description: "We value diversity, show empathy, and treat everyone with dignity."
},
{
  icon: Users,
  title: "Teamwork",
  description: "We support, uplift, and collaborate with one another to achieve more together."
},
{
  icon: Scale,
  title: "Professionalism",
  description: "We are disciplined, diligent, and structured in our work, representing our company with competence."
},
{
  icon: Sparkles,
  title: "Innovation",
  description: "We embrace creativity, growth, and empowerment, always seeking better ways to serve."
},
{
  icon: TrendingUp,
  title: "Resilience",
  description: "We adapt, persevere, and stay strong in the face of challenges, turning obstacles into opportunities."
}];


const services = [
{
  icon: Headphones,
  title: "Interpretation Services",
  description: "Over-the-phone, video, and on-site interpretation in 100+ languages. Healthcare, legal, government—we handle the sectors where mistakes aren't an option."
},
{
  icon: Users,
  title: "Customer Experience Support",
  description: "Multilingual customer service teams who understand your brand and your customers. Available 24/7 across time zones."
},
{
  icon: Building2,
  title: "Business Process Outsourcing",
  description: "From call centers to back-office operations, we handle the work that needs to get done so you can focus on growing your business."
},
{
  icon: Bot,
  title: "AI-Enhanced Solutions",
  description: "Through AI Thinking Lab, we're developing tools that make human teams more effective—not replacing people, but giving them better technology to work with."
}];


const stats = [
{ value: "100+", label: "Clients Worldwide" },
{ value: "1000+", label: "Trained Professionals" },
{ value: "7", label: "Operational Sites" },
{ value: "55+", label: "Countries Covered" }];

---
<Layout>
    <main class="min-h-screen bg-[#F8FAFC]">
      <Navigation client:load/>
      
      <PageHeader 
      heading="About Defirlex" 
      title='Breaking Language Barriers'
      image="https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68e311765f5241a3d356f305_314b597993ae3f81ca355bfa6eb4b708_courses-hero.webp"
      description="Building Real Connections, Multilingual BPO services that actually help you grow your business globally."
      buttons={[
        {
          link: '#who-we-are',
          name: 'Learn Our Story'
        }
      ]}
      />


      <section id="who-we-are" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              We Are <span class="text-[#3B82F6]">Defrilex</span>
            </h2>
          </div>
          
          <div class="space-y-6 text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
            <p>
              Defrilex is a multilingual BPO and language services company headquartered in Miami with operations across multiple countries. Since 2015, we've built a seven-figure business serving healthcare, legal, and government clients who need reliable communication across languages and borders.
            </p>
            <p>
              We're not the biggest BPO in the world—and that's intentional. We're big enough to handle complex, multi-language projects with strict compliance requirements, but small enough that you work directly with people who actually care about your outcomes.
            </p>
            <p>
              We've earned our reputation by doing what we say we'll do: delivering certified interpreters, maintaining compliance (GDPR, HIPAA, PCI-DSS), and being available 24/7 when our clients need us.
            </p>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-linear-to-br from-[#F8FAFC] to-[#EEF2FF]">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Why Work With <span class="text-[#3B82F6]">Defrilex</span>
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {whyWorkWithUs.map((item, index) =>
            <div
              class={`group bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 ${index === 4 ? 'md:col-span-2 lg:col-span-1' : ''}`}>

                <div class="w-14 h-14 rounded-2xl bg-[#3B82F6]/10 flex items-center justify-center mb-6 group-hover:bg-[#3B82F6] transition-colors duration-300">
                  <item.icon className="w-7 h-7 text-[#3B82F6] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[18px] md:text-[20px] font-bold text-[#1A1A1A] mb-3">{item.title}</h3>
                <p class="text-[14px] md:text-[15px] text-[#4A4A4A] leading-[1.7]">{item.description}</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              From Startup to <span class="text-[#3B82F6]">Seven Figures</span>
            </h2>
          </div>
          
          <div class="relative">
            <div class="absolute left-4.75 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-linear-to-b from-[#3B82F6] via-[#06B6D4] to-[#10B981]" />
            
            <div class="space-y-12">
              {timeline.map((item, index) =>
              <div class={`relative flex flex-col md:flex-row gap-6 md:gap-12 ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
                  <div class={`flex-1 ${index % 2 === 1 ? 'md:text-right' : ''}`}>
                    <div class={`bg-[#F8FAFC] rounded-2xl p-6 md:p-8 ${index % 2 === 1 ? 'md:mr-6' : 'md:ml-6'} ml-12 md:ml-0`}>
                      <span class="inline-block px-4 py-1.5 bg-[#3B82F6]/10 text-[#3B82F6] font-bold rounded-full text-[14px] mb-4 !whitespace-pre-line !whitespace-pre-line !whitespace-pre-line !whitespace-pre-line !whitespace-pre-line">{item.year}</span>
                      <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{item.title}</h3>
                      <p class="text-[14px] md:text-[15px] text-[#4A4A4A] leading-[1.7]">{item.description}</p>
                    </div>
                  </div>
                  <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 top-6 md:top-8 w-10 h-10 rounded-full bg-[#3B82F6] flex items-center justify-center shadow-lg">
                    <div class="w-3 h-3 rounded-full bg-white" />
                  </div>
                  <div class="flex-1 hidden md:block" />
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-linear-to-br from-[#1E3A5F] via-[#2D5A87] to-[#3B82F6]">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
              What We Actually <span class="text-[#67E8F9]">Stand For</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-white/70 max-w-[600px] mx-auto">
              Forget corporate value statements. Here's what drives how we operate:
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {values.map((value, index) =>
            <div
              class={`bg-white/10 backdrop-blur-sm rounded-3xl p-8 md:p-10 border border-white/10 ${index === 6 ? 'md:col-span-2 lg:col-span-1' : ''}`}>

                <div class="w-14 h-14 rounded-2xl bg-[#67E8F9]/20 flex items-center justify-center mb-6">
                  <value.icon className="w-7 h-7 text-[#67E8F9]" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-white mb-3">{value.title}</h3>
                <p class="text-[14px] md:text-[15px] text-white/70 leading-[1.7]">{value.description}</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Our <span class="text-[#3B82F6]">Services</span>
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((service, index) =>
            <div
              class="group bg-[#F8FAFC] rounded-3xl p-8 md:p-10 hover:bg-[#3B82F6] transition-colors duration-300">

                <div class="w-14 h-14 rounded-2xl bg-[#3B82F6]/10 group-hover:bg-white/20 flex items-center justify-center mb-6 transition-colors duration-300">
                  <service.icon className="w-7 h-7 text-[#3B82F6] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] group-hover:text-white mb-3 transition-colors duration-300">{service.title}</h3>
                <p class="text-[14px] md:text-[15px] text-[#4A4A4A] group-hover:text-white/80 leading-[1.7] transition-colors duration-300">{service.description}</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-[#F8FAFC]">
        <div class="max-w-[1000px] mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] leading-[1.2] mb-6">
                Our <span class="text-[#3B82F6]">Mission</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-8">
                Make global communication easy and reliable for businesses that can't afford mistakes.
              </p>
              <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">
                Whether you're a healthcare provider serving diverse populations, a legal firm with international clients, or a government agency needing certified translation—we remove the language barrier so you can focus on your actual work.
              </p>
            </div>
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] leading-[1.2] mb-6">
                Our <span class="text-[#3B82F6]">Vision</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-8">
                To be the multilingual BPO that businesses trust when quality and compliance actually matter.
              </p>
              <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">
                Not the biggest. Not the flashiest. Just the one you can count on to deliver—every time, in every language, across every border.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[900px] mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              What Our Clients <span class="text-[#3B82F6]">Say</span>
            </h2>
          </div>
          
          <div class="bg-linear-to-br from-[#F8FAFC] to-[#EEF2FF] rounded-3xl p-10 md:p-14 text-center relative">
            <Quote className="w-16 h-16 text-[#3B82F6]/20 mx-auto mb-6" />
            <blockquote class="text-[18px] md:text-[22px] text-[#1A1A1A] leading-[1.7] font-medium mb-8">
              "I can't say enough good things about Defrilex. The level of talent they have is impressive—highly skilled, reliable, and solution-oriented. They don't just take orders; they solve problems."
            </blockquote>
            <cite class="text-[15px] text-[#4A4A4A] not-italic">
              – Healthcare Services Client
            </cite>
          </div>
        </div>
      </section>

      <section class="py-[80px] md:py-[100px] px-6 bg-[#00003d]">
        <div class="max-w-[1200px] mx-auto">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
            {stats.map((stat, index) =>
            <div class="text-center">
                <p class="text-[36px] md:text-[48px] font-bold text-white mb-2">{stat.value}</p>
                <p class="text-[13px] md:text-[14px] text-white/60 uppercase tracking-wider">{stat.label}</p>
              </div>
            )}
          </div>
          <p class="text-center text-white/50 text-[14px] mt-10">
            We're proud to serve businesses that demand excellence and trust us to deliver it.
          </p>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-linear-to-br from-[#1E3A5F] via-[#2D5A87] to-[#3B82F6]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Work Together?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Let's discuss how Defrilex can help you communicate across languages and borders—reliably, compliantly, and affordably.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-white text-[#1E3A5F] font-semibold rounded-full hover:bg-[#67E8F9] transition-colors duration-300 text-[16px]">

            Get in Touch
            <ArrowRight className="w-5 h-5" />
          </a>
        </div>
      </section>

      <Footer />
    </main>
</Layout>