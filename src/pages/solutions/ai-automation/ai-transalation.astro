---

import { ArrowRight, CheckCircle, FileText, Globe, Languages, Shield, Sparkles, Users } from "lucide-react";
import Footer from "../../../components/Footer.astro";
import Navigation from "../../../components/navigation";
import Layout from "../../../layouts/Layout.astro";

const howItWorks = [
  {
    step: "01",
    title: "AI-Powered Draft",
    description: "Our neural machine translation engine processes your content instantly, handling complex terminology and context with remarkable accuracy."
  },
  {
    step: "02",
    title: "Human Review",
    description: "Native-speaking linguists review, refine, and perfect the AI output—catching nuances, cultural context, and domain-specific subtleties."
  },
  {
    step: "03",
    title: "Quality Assurance",
    description: "A second expert validates the final translation, ensuring accuracy, consistency, and brand voice alignment before delivery."
  }
];

const humanEdge = [
  {
    icon: Users,
    title: "Native Linguists",
    description: "Every translation is reviewed by native speakers who understand cultural context, idioms, and regional variations."
  },
  {
    icon: Shield,
    title: "Domain Expertise",
    description: "Our human reviewers specialize in your industry—legal, medical, technical, marketing—ensuring accurate terminology."
  },
  {
    icon: FileText,
    title: "Brand Consistency",
    description: "Human editors maintain your brand voice and style guide across all languages, preserving your unique identity."
  },
  {
    icon: Sparkles,
    title: "Creative Adaptation",
    description: "When transcreation is needed, our linguists adapt messaging for cultural resonance, not just word-for-word translation."
  }
];

const businessImpact = [
  "50% faster than traditional translation",
  "Up to 40% cost reduction vs. human-only",
  "99%+ accuracy with human verification",
  "Support for 100+ language pairs",
  "Consistent terminology across all content",
  "Scale to millions of words without quality loss"
];

---
  <Layout>
      <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      
      <section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center overflow-hidden pt-[160px] pb-[100px]">
        <div class="absolute inset-0 bg-gradient-to-br from-[#0F172A] via-[#1E293B] to-[#334155]" />
        <div class="absolute top-20 right-20 w-80 h-80 bg-[#10B981]/20 rounded-full blur-3xl" />
        <div class="absolute bottom-20 left-10 w-96 h-96 bg-[#06B6D4]/20 rounded-full blur-3xl" />
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wMyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-50" />
        
        <div class="container relative z-10 px-6 max-w-[1000px]">
          <div class="inline-flex items-center gap-2 rounded-full bg-[#10B981]/20 px-5 py-2.5 mb-8 border border-[#10B981]/30">
            <Languages className="w-4 h-4 text-[#10B981]" />
            <span class="text-[13px] font-bold text-[#10B981] uppercase tracking-wider">AI Automation</span>
          </div>
          
          <h1 class="text-[40px] sm:text-[52px] md:text-[60px] lg:text-[68px] font-bold text-white leading-[1.05] tracking-[-0.02em] mb-8">
            AI Translation
            <span class="block bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">With Human Precision</span>
          </h1>
          
          <p class="text-[17px] md:text-[19px] lg:text-[21px] text-white/70 max-w-[680px] mx-auto mb-12 leading-[1.7]">
            The perfect hybrid: machine speed meets human accuracy. Get translations that are fast, affordable, and flawless.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="#cta"
              class="w-full sm:w-auto px-10 py-4.5 bg-gradient-to-r from-[#10B981] to-[#06B6D4] text-white font-semibold rounded-full hover:opacity-90 transition-opacity duration-300 text-center text-[15px]"
            >
              Automate Your Workflow Today
            </a>
            <a
              href="#how-it-works"
              class="w-full sm:w-auto px-10 py-4.5 bg-white/10 text-white font-semibold rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 text-center text-[15px]"
            >
              See How It Works
            </a>
          </div>
        </div>
      </section>

      <section id="how-it-works" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              How It <span class="bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">Works</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[600px] mx-auto leading-[1.7]">
              Our hybrid approach combines the speed of AI with the precision of human expertise for unmatched quality.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {howItWorks.map((item, index) => (
              <div class="relative">
                <div class="text-[80px] font-bold text-[#10B981]/10 leading-none mb-4">{item.step}</div>
                <h3 class="text-[22px] md:text-[24px] font-bold text-[#1A1A1A] mb-3">{item.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{item.description}</p>
                {index < howItWorks.length - 1 && (
                  <div class="hidden md:block absolute top-16 right-0 w-12 h-0.5 bg-gradient-to-r from-[#10B981] to-transparent" />
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#ECFDF5] via-[#D1FAE5] to-[#A7F3D0]">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              The Human <span class="bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">Edge</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[650px] mx-auto leading-[1.7]">
              AI provides the speed and scale. Humans provide the judgment, cultural awareness, and creative finesse that make translations truly exceptional.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {humanEdge.map((item, index) => (
              <div 
                class="group bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#10B981]/10 flex items-center justify-center mb-6 group-hover:bg-[#10B981] transition-colors duration-300">
                  <item.icon className="w-7 h-7 text-[#10B981] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{item.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                Business <span class="bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">Impact</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Go global faster without sacrificing quality. Our hybrid model delivers the best of both worlds—speed when you need it, accuracy you can trust.
              </p>
              <div class="space-y-4">
                {businessImpact.map((impact, index) => (
                  <div class="flex items-start gap-3">
                    <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{impact}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#0F172A] to-[#1E293B] rounded-3xl p-10 md:p-12 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-40 h-40 bg-[#10B981]/20 rounded-full blur-3xl" />
                <Globe className="w-12 h-12 text-[#10B981] mb-6 relative z-10" />
                <h3 class="text-[24px] md:text-[28px] font-bold mb-4 relative z-10">Global Reach</h3>
                <p class="text-white/70 leading-[1.7] mb-8 relative z-10">
                  Translate content into 100+ languages with the confidence that every word resonates with your target audience.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/10 relative z-10">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">100+</p>
                    <p class="text-[13px] text-white/50 uppercase tracking-wider">Languages</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold bg-gradient-to-r from-[#10B981] to-[#06B6D4] bg-clip-text text-transparent">99%+</p>
                    <p class="text-[13px] text-white/50 uppercase tracking-wider">Accuracy</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="cta" class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#0F172A] via-[#1E293B] to-[#334155]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Go Global?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Get translations that are fast, accurate, and culturally resonant. Our hybrid AI + human approach is the future of localization.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-[#10B981] to-[#06B6D4] text-white font-semibold rounded-full hover:opacity-90 transition-opacity duration-300 text-[16px]"
          >
            Automate Your Workflow Today
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            Free sample translation • No commitment • 24-hour turnaround
          </p>
        </div>
      </section>

      <Footer />
    </main>
  </Layout>