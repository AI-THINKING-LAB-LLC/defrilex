---
import Navigation from "../../../components/navigation";
import Footer from "../../../components/Footer.astro";
import { Video, Monitor, Users, Wifi, HeartPulse, Scale, Building2, CheckCircle, ArrowRight, Eye } from "lucide-react";
import Layout from "../../../layouts/Layout.astro";
import SolutionHeader from "../../../components/solution-header.astro";

const features = [
  {
    icon: Video,
    title: "HD Video Quality",
    description: "Crystal-clear video ensures interpreters can read facial expressions, lip movements, and visual cues accurately."
  },
  {
    icon: Monitor,
    title: "Any Device, Anywhere",
    description: "Works on smartphones, tablets, laptops, and dedicated VRI carts. No proprietary hardware required."
  },
  {
    icon: Users,
    title: "Multi-Party Sessions",
    description: "Connect multiple participants across locations—perfect for family meetings, group consultations, and team calls."
  },
  {
    icon: Wifi,
    title: "Low-Bandwidth Mode",
    description: "Adaptive streaming technology ensures reliable connections even in areas with limited internet connectivity."
  }
];

const useCases = [
  {
    icon: HeartPulse,
    title: "Healthcare Settings",
    description: "Emergency rooms, patient consultations, mental health sessions, physical therapy demonstrations, and bedside care.",
    color: "#10B981"
  },
  {
    icon: Scale,
    title: "Legal Proceedings",
    description: "Remote depositions, virtual court hearings, attorney-client meetings, and immigration case interviews.",
    color: "#3B82F6"
  },
  {
    icon: Building2,
    title: "Business & Education",
    description: "Corporate meetings, training sessions, parent-teacher conferences, and academic counseling.",
    color: "#8B5CF6"
  }
];

const benefits = [
  "Visual context improves interpretation accuracy by 40%",
  "HIPAA-compliant secure video platform",
  "Average connection time under 60 seconds",
  "Recorded sessions available for compliance",
  "Screen sharing for document review",
  "Seamless handoff between VRI and OPI"
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      <SolutionHeader 
      heading="Video Remote"
      heading2="Interpretation"
      heading3="in 300+ Languages"
      interpreters="300+"
      image="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?w=800&q=90"
      description="Face-to-face interpretation without the travel. See and be seen for richer, more accurate communication across 300+ languages."
      buttons={[
        { name: "Request a Quote", link: "#quote" },
        { name: "See How It Works", link: "#features" }
      ]}
      />
          

      <section id="features" class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              What Makes Our VRI <span class="text-[#3B82F6]">Stand Out</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[600px] mx-auto leading-[1.7]">
              Built for scenarios where visual communication matters—healthcare, legal, and high-stakes business conversations.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div
                class="group bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 border border-[#D1D1FF]/30"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#3B82F6]/10 flex items-center justify-center mb-6 group-hover:bg-[#3B82F6] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#3B82F6] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#E0F2FE] via-[#E8F4FF] to-[#F0E8FF]">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Ideal Use Cases
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[600px] mx-auto leading-[1.7]">
              VRI excels when visual cues enhance understanding and build trust between parties.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {useCases.map((useCase, index) => (
              <div
                class="bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${useCase.color}15` }}
                >
                  <useCase.icon className="w-7 h-7" style={{ color: useCase.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{useCase.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{useCase.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                Why Choose <span class="text-[#3B82F6]">Defrilex</span> for VRI
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Our VRI platform was built by people who understand healthcare and legal compliance inside and out. We don't just provide video—we provide peace of mind.
              </p>
              <div class="space-y-4">
                {benefits.map((benefit, index) => (
                  <div class="flex items-start gap-3">
                    <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{benefit}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#3B82F6] to-[#1D4ED8] rounded-3xl p-10 md:p-12 text-white">
                <h3 class="text-[24px] md:text-[28px] font-bold mb-4">The Visual Advantage</h3>
                <div class="grid grid-cols-2 gap-8">
                  <div>
                    <p class="text-[40px] md:text-[48px] font-bold mb-1">40%</p>
                    <p class="text-[14px] text-white/80 uppercase tracking-wider">Better Accuracy</p>
                  </div>
                  <div>
                    <p class="text-[40px] md:text-[48px] font-bold mb-1">300+</p>
                    <p class="text-[14px] text-white/80 uppercase tracking-wider">Languages</p>
                  </div>
                  <div>
                    <p class="text-[40px] md:text-[48px] font-bold mb-1">&lt;60s</p>
                    <p class="text-[14px] text-white/80 uppercase tracking-wider">Connect Time</p>
                  </div>
                  <div>
                    <p class="text-[40px] md:text-[48px] font-bold mb-1">HD</p>
                    <p class="text-[14px] text-white/80 uppercase tracking-wider">Video Quality</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[80px] md:py-[100px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="flex flex-col md:flex-row items-center gap-10">
            <div class="w-20 h-20 rounded-2xl bg-[#3B82F6]/10 flex items-center justify-center flex-shrink-0">
              <Eye className="w-10 h-10 text-[#3B82F6]" />
            </div>
            <div>
              <h3 class="text-[24px] md:text-[28px] font-bold text-[#1A1A1A] mb-3">When to Choose VRI over OPI</h3>
              <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">
                Choose VRI when body language matters—medical examinations, mental health sessions, sign language interpretation, or any situation where seeing the interpreter builds trust. For quick transactional calls, OPI may be more efficient.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="quote" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Get Started?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Request a custom quote for your organization. Our team will assess your needs and provide a tailored VRI solution within 24 hours.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#3B82F6] text-white font-semibold rounded-full hover:bg-[#2563EB] transition-colors duration-300 text-[16px]"
          >
            Request a Quote
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            No commitment required. Free demo available.
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>