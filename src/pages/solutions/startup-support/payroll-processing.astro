---

import { AlertTriangle, ArrowRight, Building2, Calculator, CheckCircle, Clock, DollarSign, Rocket, Shield, Users } from "lucide-react";
import Footer from "../../../components/Footer.astro";
import Navigation from "../../../components/navigation";
import Layout from "../../../layouts/Layout.astro";

const includedServices = [
  "Bi-weekly or monthly payroll processing",
  "Direct deposit setup and management",
  "Federal, state, and local tax calculations",
  "Tax filing and compliance reporting",
  "W-2 and 1099 preparation and distribution",
  "Payroll deductions and garnishments",
  "PTO and sick leave tracking",
  "Payroll reports and analytics"
];

const features = [
  {
    icon: Clock,
    title: "On-Time, Every Time",
    description: "Never miss a pay date again. Our systems ensure your team gets paid accurately and on schedule, building the trust that retains talent."
  },
  {
    icon: Shield,
    title: "Tax Compliance Guaranteed",
    description: "We handle federal, state, and local tax calculations, filings, and remittances—so you're never surprised by penalties or audits."
  },
  {
    icon: Calculator,
    title: "Accurate to the Penny",
    description: "Multi-level verification processes catch errors before they happen. No more awkward conversations about incorrect paychecks."
  },
  {
    icon: DollarSign,
    title: "Cost-Effective Solution",
    description: "Get enterprise-grade payroll infrastructure at a fraction of the cost of building it in-house or hiring a dedicated payroll specialist."
  }
];

const industries = [
  {
    icon: Rocket,
    title: "Early-Stage Startups",
    description: "Simple, compliant payroll from your first employee without the complexity or cost of enterprise solutions.",
    color: "#3B82F6"
  },
  {
    icon: Building2,
    title: "Growing Teams",
    description: "Scale your payroll seamlessly as you add contractors, full-time employees, and new states.",
    color: "#10B981"
  },
  {
    icon: Users,
    title: "Remote & Distributed Teams",
    description: "Multi-state payroll expertise to keep you compliant wherever your team is located.",
    color: "#8B5CF6"
  }
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      
      <section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center overflow-hidden pt-[160px] pb-[100px]">
        <div class="absolute inset-0 bg-gradient-to-br from-[#EFF6FF] via-[#DBEAFE] to-[#BFDBFE]" />
        <div class="absolute top-20 right-20 w-80 h-80 bg-[#3B82F6]/10 rounded-full blur-3xl" />
        <div class="absolute bottom-20 left-10 w-96 h-96 bg-[#60A5FA]/15 rounded-full blur-3xl" />
        
        <div class="container relative z-10 px-6 max-w-[1000px]">
          <div class="inline-flex items-center gap-2 rounded-full bg-[#3B82F6]/10 px-5 py-2.5 mb-8">
            <DollarSign className="w-4 h-4 text-[#3B82F6]" />
            <span class="text-[13px] font-bold text-[#3B82F6] uppercase tracking-wider">Startup Support</span>
          </div>
          
          <h1 class="text-[40px] sm:text-[52px] md:text-[60px] lg:text-[68px] font-bold text-[#1A1A1A] leading-[1.05] tracking-[-0.02em] mb-8">
            Payroll That Just
            <span class="block text-[#3B82F6]">Works</span>
          </h1>
          
          <p class="text-[17px] md:text-[19px] lg:text-[21px] text-[#4A4A4A] max-w-[680px] mx-auto mb-12 leading-[1.7]">
            Accurate, timely payroll processing that keeps your team happy and your company compliant—so you can focus on growth.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="#consultation"
              class="w-full sm:w-auto px-10 py-4.5 bg-[#1A1A1A] text-white font-semibold rounded-full hover:bg-[#3B82F6] transition-colors duration-300 text-center text-[15px]"
            >
              Schedule a Consultation
            </a>
            <a
              href="#challenge"
              class="w-full sm:w-auto px-10 py-4.5 bg-white text-[#1A1A1A] font-semibold rounded-full border-2 border-[#1A1A1A]/10 hover:border-[#3B82F6] hover:text-[#3B82F6] transition-all duration-300 text-center text-[15px]"
            >
              Learn More
            </a>
          </div>
        </div>
      </section>

      <section id="challenge" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="flex flex-col md:flex-row items-start gap-10">
            <div class="w-20 h-20 rounded-2xl bg-[#FEF3C7] flex items-center justify-center flex-shrink-0">
              <AlertTriangle className="w-10 h-10 text-[#F59E0B]" />
            </div>
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] mb-6">The Challenge</h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-4">
                Payroll looks simple until you're doing it. Tax calculations across multiple states, varying pay schedules, contractor vs. employee classifications, benefits deductions, garnishments—the complexity compounds with every hire.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
                And the stakes are high. A payroll mistake doesn't just frustrate employees—it can trigger IRS penalties, state audits, and legal liability. For a startup founder, hours spent wrestling with payroll are hours not spent building your product or closing customers.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              The <span class="text-[#3B82F6]">Solution</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[650px] mx-auto leading-[1.7]">
              We take payroll completely off your plate—from calculations and processing to tax filings and compliance. You approve, we execute, your team gets paid.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div
                class="group bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 border border-[#3B82F6]/10"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#3B82F6]/10 flex items-center justify-center mb-6 group-hover:bg-[#3B82F6] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#3B82F6] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#EFF6FF] via-[#DBEAFE] to-[#BFDBFE]">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                What's <span class="text-[#3B82F6]">Included</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Complete end-to-end payroll management that grows with your company—from your first hire to your hundredth.
              </p>
              <div class="grid grid-cols-1 gap-3">
                {includedServices.map((service, index) => (
                  <div class="flex items-start gap-3 bg-white/60 backdrop-blur-sm rounded-xl p-4">
                    <CheckCircle className="w-5 h-5 text-[#3B82F6] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{service}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#3B82F6] to-[#1D4ED8] rounded-3xl p-10 md:p-12 text-white">
                <h3 class="text-[24px] md:text-[28px] font-bold mb-6">Payroll Peace of Mind</h3>
                <p class="text-white/90 leading-[1.7] mb-8">
                  We've processed thousands of payrolls without missing a deadline or triggering a penalty. Your employees and the IRS will both be happy.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/20">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">100%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">On-Time Rate</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">99.9%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Accuracy Rate</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Perfect For
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {industries.map((industry, index) => (
              <div
                class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${industry.color}15` }}
                >
                  <industry.icon className="w-7 h-7" style={{ color: industry.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{industry.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="consultation" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Simplify Payroll?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Schedule a free consultation to discuss your payroll needs. We'll review your current setup, identify pain points, and show you how easy payroll can be.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#3B82F6] text-white font-semibold rounded-full hover:bg-[#1D4ED8] transition-colors duration-300 text-[16px]"
          >
            Schedule Your Free Consultation
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            30-minute call • No commitment • Get a custom quote
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>