---

import { AlertTriangle, ArrowRight, Building2, CheckCircle, Clock, FileText, Receipt, Rocket, ShoppingCart, TrendingUp } from "lucide-react";
import Footer from "../../../components/Footer.astro";
import Navigation from "../../../components/navigation";
import Layout from "../../../layouts/Layout.astro";
import SolutionHeader from "../../../components/solution-header.astro";

const includedServices = [
  "Invoice generation and distribution",
  "Accounts receivable management",
  "Payment processing and reconciliation",
  "Dunning and collections follow-up",
  "Subscription billing management",
  "Revenue recognition reporting",
  "Customer billing inquiries",
  "Financial reporting and analytics"
];

const features = [
  {
    icon: TrendingUp,
    title: "Improved Cash Flow",
    description: "Consistent invoicing and proactive follow-ups mean faster payments and more predictable revenue cycles."
  },
  {
    icon: Clock,
    title: "Time Savings",
    description: "Stop spending founder hours on invoicing and payment chasing. We handle the entire billing workflow end-to-end."
  },
  {
    icon: FileText,
    title: "Clean Records",
    description: "Organized financial records that make tax time, audits, and investor due diligence painless."
  },
  {
    icon: Receipt,
    title: "Professional Experience",
    description: "Your customers receive polished invoices and responsive billing support that reflects well on your brand."
  }
];

const industries = [
  {
    icon: Rocket,
    title: "SaaS & Subscription",
    description: "Manage recurring billing, upgrades, downgrades, and prorations without the complexity.",
    color: "#8B5CF6"
  },
  {
    icon: Building2,
    title: "Professional Services",
    description: "Project-based billing, retainer management, and time-based invoicing made simple.",
    color: "#10B981"
  },
  {
    icon: ShoppingCart,
    title: "E-Commerce & Marketplaces",
    description: "High-volume transaction processing and vendor payouts handled efficiently.",
    color: "#3B82F6"
  }
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      <SolutionHeader  
      heading="Billing Support"
      heading2="That Keeps Cash Flowing"
      interpreters="50+"
      peopleType="Revenue Operations Specialists"
      image="https://images.unsplash.com/photo-1649209979970-f01d950cc5ed?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NHx8YmlsbGluZ3xlbnwwfHwwfHx8MA%3D%3D"
      description="Professional billing management to streamline your financial operations and accelerate collections."
      buttons={[
        { name: "Schedule a Consultation", link: "#consultation" },
        { name: "Learn More", link: "#challenge" }
      ]}
      />
      

      <section id="challenge" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="flex flex-col md:flex-row items-start gap-10">
            <div class="w-20 h-20 rounded-2xl bg-[#FEF3C7] flex items-center justify-center flex-shrink-0">
              <AlertTriangle className="w-10 h-10 text-[#F59E0B]" />
            </div>
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] mb-6">The Challenge</h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-4">
                Revenue doesn't matter if you can't collect it. Yet billing often falls through the cracks at growing startups—invoices go out late (or not at all), follow-ups don't happen, and cash flow suffers.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
                Meanwhile, your finance "system" is probably a combination of spreadsheets, email threads, and mental notes. This works until it doesn't—usually right when you need clean books for investors or an audit.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              The <span class="text-[#8B5CF6]">Solution</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[650px] mx-auto leading-[1.7]">
              We become your billing operations team—ensuring invoices go out on time, payments come in faster, and your financial records stay impeccable.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div
                class="group bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 border border-[#8B5CF6]/10"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#8B5CF6]/10 flex items-center justify-center mb-6 group-hover:bg-[#8B5CF6] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#8B5CF6] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#F5F3FF] via-[#EDE9FE] to-[#DDD6FE]">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                What's <span class="text-[#8B5CF6]">Included</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Complete billing operations support that keeps your revenue flowing and your books clean.
              </p>
              <div class="grid grid-cols-1 gap-3">
                {includedServices.map((service, index) => (
                  <div class="flex items-start gap-3 bg-white/60 backdrop-blur-sm rounded-xl p-4">
                    <CheckCircle className="w-5 h-5 text-[#8B5CF6] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{service}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#8B5CF6] to-[#7C3AED] rounded-3xl p-10 md:p-12 text-white">
                <h3 class="text-[24px] md:text-[28px] font-bold mb-6">Financial Clarity</h3>
                <p class="text-white/90 leading-[1.7] mb-8">
                  Know exactly where your money is at all times. Our systems and processes bring order to your billing chaos and accelerate your cash conversion cycle.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/20">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">30%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Faster Collections</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">98%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Invoice Accuracy</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Perfect For
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {industries.map((industry, index) => (
              <div
                class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${industry.color}15` }}
                >
                  <industry.icon className="w-7 h-7" style={{ color: industry.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{industry.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="consultation" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Optimize Billing?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Schedule a free consultation to discuss your billing operations. We'll review your current processes, identify bottlenecks, and show you how to accelerate collections.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#8B5CF6] text-white font-semibold rounded-full hover:bg-[#7C3AED] transition-colors duration-300 text-[16px]"
          >
            Schedule Your Free Consultation
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            30-minute call • No commitment • Free billing audit included
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>