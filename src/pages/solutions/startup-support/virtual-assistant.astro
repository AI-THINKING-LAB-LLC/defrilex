---
import Navigation from "../../../components/navigation";
import Footer from "../../../components/Footer.astro";
import { User, Calendar, Mail, Search, Rocket, Building2, Briefcase, CheckCircle, ArrowRight, AlertTriangle } from "lucide-react";
import Layout from "../../../layouts/Layout.astro";

const includedServices = [
  "Email and inbox management",
  "Calendar management and scheduling",
  "Travel booking and coordination",
  "Research and data gathering",
  "Document preparation and formatting",
  "Expense tracking and reporting",
  "Meeting preparation and follow-ups",
  "Personal task management"
];

const features = [
  {
    icon: Calendar,
    title: "Time Optimization",
    description: "Reclaim 10+ hours per week. Your VA handles scheduling, coordination, and administrative tasks so you focus on high-impact work."
  },
  {
    icon: Mail,
    title: "Inbox Zero",
    description: "A managed inbox means important messages get attention and nothing falls through the cracks. We triage, respond, and escalate appropriately."
  },
  {
    icon: Search,
    title: "Research on Demand",
    description: "Need market research, competitive analysis, or due diligence? Your VA delivers thorough, well-organized findings."
  },
  {
    icon: User,
    title: "Dedicated Support",
    description: "Work with a dedicated assistant who learns your preferences, anticipates your needs, and becomes an extension of your team."
  }
];

const industries = [
  {
    icon: Rocket,
    title: "Startup Founders",
    description: "Focus on vision and execution while your VA handles the administrative load that comes with running a company.",
    color: "#EC4899"
  },
  {
    icon: Building2,
    title: "Executives & Leaders",
    description: "Maximize your leadership capacity with support for scheduling, communications, and meeting prep.",
    color: "#10B981"
  },
  {
    icon: Briefcase,
    title: "Sales & BD Teams",
    description: "Prospecting research, CRM updates, meeting coordination, and follow-up management.",
    color: "#3B82F6"
  }
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      
      <section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center overflow-hidden pt-[160px] pb-[100px]">
        <div class="absolute inset-0 bg-gradient-to-br from-[#FDF2F8] via-[#FCE7F3] to-[#FBCFE8]" />
        <div class="absolute top-20 left-20 w-80 h-80 bg-[#EC4899]/10 rounded-full blur-3xl" />
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-[#F472B6]/15 rounded-full blur-3xl" />
        
        <div class="container relative z-10 px-6 max-w-[1000px]">
          <div class="inline-flex items-center gap-2 rounded-full bg-[#EC4899]/10 px-5 py-2.5 mb-8">
            <User className="w-4 h-4 text-[#EC4899]" />
            <span class="text-[13px] font-bold text-[#EC4899] uppercase tracking-wider">Startup Support</span>
          </div>
          
          <h1 class="text-[40px] sm:text-[52px] md:text-[60px] lg:text-[68px] font-bold text-[#1A1A1A] leading-[1.05] tracking-[-0.02em] mb-8">
            Your Dedicated
            <span class="block text-[#EC4899]">Virtual Assistant</span>
          </h1>
          
          <p class="text-[17px] md:text-[19px] lg:text-[21px] text-[#4A4A4A] max-w-[680px] mx-auto mb-12 leading-[1.7]">
            Dedicated virtual assistants to handle tasks and boost your productivity—giving you back the time to focus on what only you can do.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="#consultation"
              class="w-full sm:w-auto px-10 py-4.5 bg-[#1A1A1A] text-white font-semibold rounded-full hover:bg-[#EC4899] transition-colors duration-300 text-center text-[15px]"
            >
              Schedule a Consultation
            </a>
            <a
              href="#challenge"
              class="w-full sm:w-auto px-10 py-4.5 bg-white text-[#1A1A1A] font-semibold rounded-full border-2 border-[#1A1A1A]/10 hover:border-[#EC4899] hover:text-[#EC4899] transition-all duration-300 text-center text-[15px]"
            >
              Learn More
            </a>
          </div>
        </div>
      </section>

      <section id="challenge" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="flex flex-col md:flex-row items-start gap-10">
            <div class="w-20 h-20 rounded-2xl bg-[#FEF3C7] flex items-center justify-center flex-shrink-0">
              <AlertTriangle className="w-10 h-10 text-[#F59E0B]" />
            </div>
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] mb-6">The Challenge</h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-4">
                Your calendar is a battlefield. Your inbox is a black hole. You're spending hours on scheduling, travel logistics, research, and administrative tasks that anyone could do—but they're eating into the time you should spend on strategy, customers, and growth.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
                You know you need support, but hiring a full-time executive assistant doesn't make sense yet. And the freelancer you tried last time disappeared mid-project. You need reliable, professional support that scales with your needs.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              The <span class="text-[#EC4899]">Solution</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[650px] mx-auto leading-[1.7]">
              A dedicated virtual assistant who learns your preferences, anticipates your needs, and handles the daily tasks that consume your time and mental energy.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div 
                class="group bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 border border-[#EC4899]/10"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#EC4899]/10 flex items-center justify-center mb-6 group-hover:bg-[#EC4899] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#EC4899] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#FDF2F8] via-[#FCE7F3] to-[#FBCFE8]">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                What's <span class="text-[#EC4899]">Included</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Comprehensive virtual assistant support tailored to your specific needs and work style.
              </p>
              <div class="grid grid-cols-1 gap-3">
                {includedServices.map((service, index) => (
                  <div class="flex items-start gap-3 bg-white/60 backdrop-blur-sm rounded-xl p-4">
                    <CheckCircle className="w-5 h-5 text-[#EC4899] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{service}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#EC4899] to-[#DB2777] rounded-3xl p-10 md:p-12 text-white">
                <h3 class="text-[24px] md:text-[28px] font-bold mb-6">Your Time, Multiplied</h3>
                <p class="text-white/90 leading-[1.7] mb-8">
                  Our VAs are trained professionals who treat your time like gold. They don't just complete tasks—they proactively identify ways to make your day more efficient.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/20">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">10+</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Hours Saved/Week</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">98%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Client Retention</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Perfect For
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {industries.map((industry, index) => (
              <div 
                class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${industry.color}15` }}
                >
                  <industry.icon className="w-7 h-7" style={{ color: industry.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{industry.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="consultation" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Get Your Time Back?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Schedule a free consultation to discuss your needs. We'll match you with a VA who fits your work style and can start making an impact from day one.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#EC4899] text-white font-semibold rounded-full hover:bg-[#DB2777] transition-colors duration-300 text-[16px]"
          >
            Schedule Your Free Consultation
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            30-minute call • No commitment • Start within 48 hours
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>