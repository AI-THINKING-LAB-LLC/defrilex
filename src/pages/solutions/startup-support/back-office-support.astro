---

import Navigation from "../../../components/navigation";
import Footer from "../../../components/Footer.astro";
import { Settings, Database, FileSearch, Zap, Rocket, Building2, ShoppingCart, CheckCircle, ArrowRight, AlertTriangle } from "lucide-react";
import Layout from "../../../layouts/Layout.astro";
import SolutionHeader from "../../../components/solution-header.astro";

const includedServices = [
  "Data entry and database management",
  "Document processing and organization",
  "Research and information gathering",
  "Reporting and analytics preparation",
  "CRM and system administration",
  "Vendor management and coordination",
  "Order processing and fulfillment support",
  "Quality assurance and verification"
];

const features = [
  {
    icon: Zap,
    title: "Operational Efficiency",
    description: "Free your team from time-consuming administrative tasks so they can focus on high-value work that drives growth."
  },
  {
    icon: Database,
    title: "Accurate Data Management",
    description: "Clean, organized data that powers better decisions. We maintain your systems with precision and care."
  },
  {
    icon: FileSearch,
    title: "Process Documentation",
    description: "We document and optimize your processes as we work, building institutional knowledge that scales with you."
  },
  {
    icon: Settings,
    title: "Flexible Support",
    description: "Scale support up or down based on your needs. No rigid contracts—just the help you need, when you need it."
  }
];

const industries = [
  {
    icon: Rocket,
    title: "High-Growth Startups",
    description: "Keep operations running smoothly while your team focuses on product and customers.",
    color: "#F97316"
  },
  {
    icon: ShoppingCart,
    title: "E-Commerce Businesses",
    description: "Order processing, inventory updates, vendor coordination, and customer data management.",
    color: "#10B981"
  },
  {
    icon: Building2,
    title: "Professional Services",
    description: "Contract management, document preparation, scheduling, and client database maintenance.",
    color: "#3B82F6"
  }
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      <SolutionHeader  
      heading="Back-Office Support"
      heading2="That Just Runs"
      interpreters="50+"
      peopleType="Back-Office Specialists"
      image="https://images.unsplash.com/photo-1522071901873-411886a10004?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      description="Essential administrative services to keep your business running smoothly behind the scenes—so your team can focus on what matters."
      buttons={[
        { name: "Schedule a Consultation", link: "#consultation" },
        { name: "Learn More", link: "#challenge" }
      ]}
      />

      <section id="challenge" class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1000px] mx-auto">
          <div class="flex flex-col md:flex-row items-start gap-10">
            <div class="w-20 h-20 rounded-2xl bg-[#FEF3C7] flex items-center justify-center flex-shrink-0">
              <AlertTriangle className="w-10 h-10 text-[#F59E0B]" />
            </div>
            <div>
              <h2 class="text-[28px] md:text-[36px] font-bold text-[#1A1A1A] mb-6">The Challenge</h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-4">
                Administrative work is invisible until it's not done. Data gets stale. Systems fall out of sync. Documents pile up. Orders slip through cracks. And suddenly your team is drowning in operational debt instead of building your product.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
                You can't afford a full-time operations team, but you can't afford to let these tasks slide either. Every hour your engineers spend on data entry is an hour not spent shipping features. Every founder hour spent on admin is an hour not spent on strategy.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              The <span class="text-[#F97316]">Solution</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[650px] mx-auto leading-[1.7]">
              We handle the operational tasks that keep your business running—data management, document processing, system admin, and everything in between.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div
                class="group bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 border border-[#F97316]/10"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#F97316]/10 flex items-center justify-center mb-6 group-hover:bg-[#F97316] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#F97316] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#FFF7ED] via-[#FFEDD5] to-[#FED7AA]">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                What's <span class="text-[#F97316]">Included</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.7] mb-8">
                Flexible back-office support that adapts to your business needs and grows with your company.
              </p>
              <div class="grid grid-cols-1 gap-3">
                {includedServices.map((service, index) => (
                  <div class="flex items-start gap-3 bg-white/60 backdrop-blur-sm rounded-xl p-4">
                    <CheckCircle className="w-5 h-5 text-[#F97316] flex-shrink-0 mt-0.5" />
                    <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{service}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#F97316] to-[#EA580C] rounded-3xl p-10 md:p-12 text-white">
                <h3 class="text-[24px] md:text-[28px] font-bold mb-6">Operational Excellence</h3>
                <p class="text-white/90 leading-[1.7] mb-8">
                  We don't just execute tasks—we optimize them. Over time, we identify inefficiencies, suggest improvements, and help you build scalable operations.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/20">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">40%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Time Savings</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">99%</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">Task Accuracy</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Perfect For
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {industries.map((industry, index) => (
              <div
                class="bg-white rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${industry.color}15` }}
                >
                  <industry.icon className="w-7 h-7" style={{ color: industry.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{industry.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="consultation" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Ready to Streamline Operations?
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Schedule a free consultation to discuss your operational needs. We'll review your current workflows, identify bottlenecks, and show you how to free up your team's time.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#F97316] text-white font-semibold rounded-full hover:bg-[#EA580C] transition-colors duration-300 text-[16px]"
          >
            Schedule Your Free Consultation
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            30-minute call • No commitment • Workflow audit included
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>