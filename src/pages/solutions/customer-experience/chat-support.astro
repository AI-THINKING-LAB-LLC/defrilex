---

import { ArrowRight, Bot, Building2, CheckCircle, Clock, MessageCircle, Plane, ShoppingCart, Users, Zap } from "lucide-react";
import Footer from "../../../components/Footer.astro";
import Navigation from "../../../components/navigation";
import Layout from "../../../layouts/Layout.astro";
import SolutionHeader from "../../../components/solution-header.astro";

const features = [
  {
    icon: Zap,
    title: "Instant Response Times",
    description: "Average first response in under 30 seconds. No waiting, no frustration—just immediate help when customers need it."
  },
  {
    icon: Bot,
    title: "AI-Assisted Efficiency",
    description: "Smart routing, suggested responses, and chatbot handoffs help agents resolve more conversations in less time."
  },
  {
    icon: Users,
    title: "Concurrent Conversations",
    description: "Our agents expertly manage 3-5 simultaneous chats without sacrificing quality or personalization."
  },
  {
    icon: Clock,
    title: "Extended Hours Coverage",
    description: "From standard business hours to 24/7 coverage—scale your chat availability to match customer demand."
  }
];

const industries = [
  {
    icon: ShoppingCart,
    title: "E-Commerce",
    description: "Product inquiries, order tracking, checkout assistance, and real-time inventory questions.",
    color: "#10B981"
  },
  {
    icon: Building2,
    title: "Financial Services",
    description: "Account inquiries, transaction support, loan questions, and secure document collection.",
    color: "#3B82F6"
  },
  {
    icon: Plane,
    title: "Travel & Hospitality",
    description: "Booking modifications, loyalty program support, and real-time travel assistance.",
    color: "#8B5CF6"
  }
];

const benefits = [
  "30-second average first response time",
  "95%+ customer satisfaction on chat",
  "Seamless chatbot-to-human escalation",
  "Proactive chat engagement triggers",
  "Full conversation transcripts and analytics",
  "Integration with all major chat platforms"
];
---
<Layout>
    <main class="min-h-screen bg-[#F0F0FF]">
      <Navigation client:load/>
      <SolutionHeader  
      heading="Chat Support"
      heading2="That Converts"
      interpreters="50+"
      peopleType="Chat Agents"
      image="https://images.unsplash.com/photo-1552068751-34cb5cf055b3?q=80&w=765&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      description="Real-time chat assistance providing instant solutions to customer inquiries. Turn browsers into buyers with responsive, helpful conversations."
      buttons={[
        { name: "Launch Chat Support", link: "#quote" },
        { name: "See How It Works", link: "#solution" }
      ]}
      />
      <section id="solution" class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1200px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            <div class="w-full lg:w-1/2">
              <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
                The <span class="text-[#A855F7]">Solution</span>
              </h2>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-6">
                Today's customers expect instant answers. Email is too slow. Phone calls are too much effort. Chat bridges the gap—delivering immediate, convenient support that meets customers where they already are.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8] mb-6">
                Our chat agents are trained in the art of text-based communication: clear, concise, and friendly. They know how to read tone through text, de-escalate frustrated customers, and guide conversations toward resolution.
              </p>
              <p class="text-[16px] md:text-[18px] text-[#4A4A4A] leading-[1.8]">
                Combined with AI-powered tools that suggest responses, automate routine queries, and intelligently route complex issues, our chat support delivers both speed and quality at scale.
              </p>
            </div>
            <div class="w-full lg:w-1/2">
              <div class="bg-gradient-to-br from-[#A855F7] to-[#7C3AED] rounded-3xl p-10 md:p-12 text-white">
                <MessageCircle className="w-12 h-12 mb-6" />
                <h3 class="text-[24px] md:text-[28px] font-bold mb-4">Chat That Performs</h3>
                <p class="text-white/90 leading-[1.7] mb-6">
                  Chat isn't just support—it's a conversion channel. Our agents are trained to identify sales opportunities, answer pre-purchase questions, and guide customers to checkout.
                </p>
                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/20">
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">&lt;30s</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">First Response</p>
                  </div>
                  <div>
                    <p class="text-[32px] md:text-[40px] font-bold">95%+</p>
                    <p class="text-[13px] text-white/70 uppercase tracking-wider">CSAT Rating</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-white">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Key <span class="text-[#A855F7]">Features</span>
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[600px] mx-auto leading-[1.7]">
              Modern chat support powered by skilled agents and smart technology.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {features.map((feature, index) => (
              <div
                class="group bg-[#FDF4FF] rounded-3xl p-8 md:p-10 hover:shadow-xl transition-all duration-300 border border-[#A855F7]/10"
              >
                <div class="w-14 h-14 rounded-2xl bg-[#A855F7]/10 flex items-center justify-center mb-6 group-hover:bg-[#A855F7] transition-colors duration-300">
                  <feature.icon className="w-7 h-7 text-[#A855F7] group-hover:text-white transition-colors duration-300" />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-3">{feature.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6 bg-gradient-to-br from-[#FDF4FF] via-[#FAE8FF] to-[#F5E0FF]">
        <div class="max-w-[1200px] mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Industry Applications
            </h2>
            <p class="text-[16px] md:text-[18px] text-[#4A4A4A] max-w-[600px] mx-auto leading-[1.7]">
              Chat support tailored to your industry's unique conversation patterns.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {industries.map((industry, index) => (
              <div
                class="bg-white/80 backdrop-blur-sm rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300"
              >
                <div 
                  class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6"
                  style={{ backgroundColor: `${industry.color}15` }}
                >
                  <industry.icon className="w-7 h-7" style={{ color: industry.color }} />
                </div>
                <h3 class="text-[20px] md:text-[22px] font-bold text-[#1A1A1A] mb-4">{industry.title}</h3>
                <p class="text-[15px] md:text-[16px] text-[#4A4A4A] leading-[1.7]">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-[100px] md:py-[140px] px-6">
        <div class="max-w-[1000px] mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-[#1A1A1A] leading-[1.1] mb-6">
              Why Partner With <span class="text-[#A855F7]">Defrilex</span>
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {benefits.map((benefit, index) => (
              <div class="flex items-start gap-3 bg-white rounded-2xl p-5 shadow-sm">
                <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                <span class="text-[15px] md:text-[16px] text-[#1A1A1A] font-medium">{benefit}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="quote" class="py-[100px] md:py-[140px] px-6 bg-[#1A1A1A]">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[32px] md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-6">
            Add Chat to Your Support Mix
          </h2>
          <p class="text-[16px] md:text-[18px] text-white/70 max-w-[550px] mx-auto leading-[1.7] mb-10">
            Your customers are ready to chat. Are you? Let us staff your chat channel with trained agents who convert conversations into satisfied customers.
          </p>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-10 py-5 bg-[#A855F7] text-white font-semibold rounded-full hover:bg-[#7C3AED] transition-colors duration-300 text-[16px]"
          >
            Get Your Chat Support Quote
            <ArrowRight className="w-5 h-5" />
          </a>
          <p class="mt-6 text-[14px] text-white/50">
            Free platform audit • No commitment required • Launch in 2 weeks
          </p>
        </div>
      </section>

      <Footer />
    </main>
</Layout>