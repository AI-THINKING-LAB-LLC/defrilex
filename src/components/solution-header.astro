---
const { heading, heading2, heading3, description, buttons, image, interpreters, peopleType = 'Interpreters' } = Astro.props;
---
<div class="min-h-scr w-full flex items-center justify-center pb-4 px-4 lg:pb-8 lg:px-8 pt-32 bg-[#F3F4F6]">
<div class="bg-white w-full max-w-[1400px] rounded-[3rem] shadow-xl overflow-hidden p-6 lg:p-10 relative">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 min-h-[500px]">
    {/* Left Content Card */}
    <div class="lg:col-span-7 bg-brand-cream rounded-[2.5rem] p-2 lg:p-12 flex flex-col justify-center relative overflow-hidden group">
      
      {/* Subtle background decoration */}
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

      <div class="relative z-10 max-w-xl">
        <h1 class="text-4xl lg:text-[3.5rem] leading-[1.1] font-bold text-gray-900 mb-2">
          {heading}
          <br />
          {heading2}
          <br />
          <span class="font-serif italic text-brand-purple font-light">{heading3}</span>
        </h1>

        <p class="mt-6 text-gray-600 text-lg lg:max-w-md leading-relaxed">
           {description}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          {!!buttons?.[0] ? (
            <a href={buttons[0].link} class="flex items-center gap-3 px-6 py-2 bg-[#00003d] text-white rounded-full hover:bg-[#1B3B6F] transition-all group/btn shadow-lg shadow-brand-dark/20">
            <span class="font-medium">Request a Quote</span>

          </a>
          ): null}
          {!!buttons?.[1] ? (
          <a href={buttons[1].link} class="px-8 py-3 bg-white text-brand-dark font-medium rounded-full hover:shadow-md transition-all border border-[#00003d] hover:border-gray-200">
            {buttons[1].name}
          </a>
          ): null}
        </div>

        <div class="mt-12 flex items-center gap-4">
          <div class="flex -space-x-3">
            {[1, 2, 3].map((i) => (
              <div  class="w-10 h-10 rounded-full border-2 border-brand-cream bg-gray-200 overflow-hidden relative">
                 <img 
                  src={`https://picsum.photos/100/100?random=${i + 10}`} 
                  alt="Doctor Avatar" 
                  class="w-full h-full object-cover"
                 />
              </div>
            ))}
          </div>
          <span class="text-brand-dark font-semibold">{interpreters} Certified {peopleType}</span>
        </div>
      </div>
    </div>

    {/* Right Image/Info Card */}
    <div class="lg:col-span-5 flex flex-col gap-6">
      {/* Doctor Image Card */}
      <div class="flex-1 bg-brand-dark rounded-[2.5rem] relative overflow-hidden min-h-[300px] group">
        <img 
          src={image}
          alt=""
          class="w-full h-full object-cover object-top opacity-90 group-hover:scale-105 transition-transform duration-700 max-h-[600px]"
        />
        
       
      </div>

      {/* Doctor Detail Card */}
      <!-- <div class="bg-brand-cream rounded-[2rem] p-6 flex items-center justify-between group cursor-pointer hover:bg-[#e8e6df] transition-colors">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 font-serif">Dr. James Cart</h3>
          <p class="text-gray-500 mt-1">Neurologist</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#205295] text-white flex items-center justify-center group-hover:rotate-45 transition-transform duration-300">
          <ArrowUpRight size={20} />
        </div>
      </div> -->
    </div>
  </div>
  </div>
  </div>