<section class="relative overflow-hidden bg-[#F0F0FF] py-[80px] md:py-[100px] lg:py-[140px]">
    <div class="container relative mx-auto px-4 md:px-6 max-w-[1280px] min-h-[300px] md:min-h-[400px]">
    <div class="hidden lg:block absolute inset-0 z-0 pointer-events-none">
        {avatars.map((avatar, index) => (
        <div
            class={`absolute rounded-full border-[3px] border-white shadow-lg overflow-hidden ${avatar.className}`}
        >
            <img
            src={avatar.url}
            alt={avatar.alt}
            class="object-cover"
            />
        </div>
        ))}
    </div>

    <div class="relative z-10 flex flex-col items-center text-center py-6 md:py-10">
        <h2 class="mb-4 md:mb-5 text-[28px] sm:text-[36px] md:text-[40px] lg:text-[44px] xl:text-[48px] font-bold leading-[1.15] text-[#1A1A1A]">
        Ready to start?
        </h2>
        
        <p class="mx-auto mb-6 md:mb-8 max-w-[580px] text-[14px] md:text-[15px] lg:text-[17px] leading-[1.6] text-[#4A4A4A] px-2">
        Connect with our team of experts and let us guide you in exploring & implementing our innovative solutions tailored to your business needs
        </p>

        <a
        href="#"
        class="inline-flex h-[44px] md:h-[50px] items-center justify-center rounded-full bg-[#1A1A1A] px-6 md:px-8 text-[14px] md:text-[15px] font-semibold text-white transition-colors duration-300 hover:bg-[#00005a]"
        >
        Get started
        </a>
    </div>
    
    <div class="mt-8 md:mt-10 flex flex-wrap justify-center gap-2 md:gap-3 lg:hidden">
        {avatars.slice(0, 5).map((avatar, index) => (
        <div
            class="relative h-[45px] w-[45px] md:h-[55px] md:w-[55px] overflow-hidden rounded-full border-2 border-white shadow-md"
        >
            <img
            src={avatar.url}
            alt={avatar.alt}
            class="object-cover"
            />
        </div>
        ))}
    </div>
    </div>
</section>