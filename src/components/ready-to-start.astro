      alt: "Team member 1",
      className: "top-[5%] left-[8%] w-[70px] h-[70px] md:w-[80px] md:h-[80px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5edeb18f3aa7e6648_teachable-flag-it.svg",
      alt: "Team member 2",
      className: "top-[15%] left-[25%] w-[55px] h-[55px] md:w-[65px] md:h-[65px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5aa321b1ddf67748f_teachable-flag-ae.svg",
      alt: "Team member 3",
      className: "top-[8%] right-[25%] w-[60px] h-[60px] md:w-[70px] md:h-[70px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5f2f2058a2589834f_teachable-flag-fr.svg",
      alt: "Team member 4",
      className: "top-[20%] right-[8%] w-[75px] h-[75px] md:w-[85px] md:h-[85px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5e5a86118515ff805_teachable-flag-es.svg",
      alt: "Team member 5",
      className: "bottom-[20%] left-[10%] w-[65px] h-[65px] md:w-[75px] md:h-[75px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5fe2e5883e6d7fc92_teachable-flag-de.svg",
      alt: "Team member 6",
      className: "bottom-[10%] left-[28%] w-[70px] h-[70px] md:w-[80px] md:h-[80px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5f08fdd7fd0a7772e_teachable-flag-ja.svg",
      alt: "Team member 7",
      className: "bottom-[12%] right-[28%] w-[55px] h-[55px] md:w-[65px] md:h-[65px]"
    },
    {
      url: "https://cdn.prod.website-files.com/687904fb2b26c434698c47e9/68d2c6d5347ef46d02bff6ba_teachable-flag-gb.svg",
      alt: "Team member 8",
      className: "bottom-[22%] right-[10%] w-[70px] h-[70px] md:w-[80px] md:h-[80px]"
