---
const certificationLogos = [
  {
    src: "https://slelguoygbfzlpylpxfs.supabase.co/storage/v1/object/public/test-clones/79d6b238-278f-4c8e-a7ff-62656440c3cd-kalam-cx/assets/images/6712ef57a16940d1fcd24468_ATA-Logo-19.avif",
    alt: "American Translators Association",
    height: 70,
  },
  {
    src: "https://slelguoygbfzlpylpxfs.supabase.co/storage/v1/object/public/test-clones/79d6b238-278f-4c8e-a7ff-62656440c3cd-kalam-cx/assets/images/6712ef5712d7e4cce67889f6_ALC-20.avif",
    alt: "Association of Language Companies",
    height: 40,
  },
  {
    src: "https://slelguoygbfzlpylpxfs.supabase.co/storage/v1/object/public/test-clones/79d6b238-278f-4c8e-a7ff-62656440c3cd-kalam-cx/assets/images/674b82f8d4e78f5f3ce1b7e1_Image20241130220808-21.avif",
    alt: "elia. european language industry association",
    height: 65,
  },
  {
    src: "https://slelguoygbfzlpylpxfs.supabase.co/storage/v1/object/public/test-clones/79d6b238-278f-4c8e-a7ff-62656440c3cd-kalam-cx/assets/images/6712ef57d5ffa7707685a5dc_Gala-Logo-22.avif",
    alt: "GALA Globalization & Localization Association",
    height: 60,
  },
];
---
    <section class="relative w-full py-[80px] md:py-[120px] bg-[#F0F0FF] overflow-hidden">
      <div class="container mx-auto max-w-[1280px] px-4 md:px-8 lg:px-12">
        {/* Section Heading */}
        <div class="text-center mb-10 md:mb-16">
          <h2 class="text-[#1A1A1A] text-[28px] sm:text-[36px] md:text-[42px] lg:text-[48px] font-bold leading-[1.2] mb-4 font-display">
            We Take Your Data and Compliance Seriously
          </h2>
          <p class="text-[#1A1A1A] text-[15px] md:text-[18px] font-medium opacity-80 font-body">
            Current Certifications: GDPR, HIPAA, PCI-DSS
          </p>
        </div>

        {/* Main Content */}
        <div class="space-y-8 md:space-y-12">
          {/* Intro */}
          <p class="text-[#4A4A4A] text-[15px] md:text-[18px] leading-[1.7] font-body max-w-[900px]">
            Here's what matters: if you're in healthcare, legal, government, or any industry where data protection isn't optional we've got you covered.
          </p>

          {/* Certifications List */}
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
            <div class="bg-white/40 backdrop-blur-sm rounded-[16px] p-5 md:p-6">
              <h3 class="text-[#1A1A1A] text-[18px] md:text-[20px] font-bold mb-2 md:mb-3 font-display">GDPR Compliant</h3>
              <p class="text-[#4A4A4A] text-[14px] md:text-[16px] leading-[1.6] font-body">Your European data is protected according to the world's strictest privacy standards</p>
            </div>
            <div class="bg-white/40 backdrop-blur-sm rounded-[16px] p-5 md:p-6">
              <h3 class="text-[#1A1A1A] text-[18px] md:text-[20px] font-bold mb-2 md:mb-3 font-display">HIPAA Compliant</h3>
              <p class="text-[#4A4A4A] text-[14px] md:text-[16px] leading-[1.6] font-body">Healthcare information stays secure and confidential, period</p>
            </div>
            <div class="bg-white/40 backdrop-blur-sm rounded-[16px] p-5 md:p-6 sm:col-span-2 md:col-span-1">
              <h3 class="text-[#1A1A1A] text-[18px] md:text-[20px] font-bold mb-2 md:mb-3 font-display">PCI-DSS Certified</h3>
              <p class="text-[#4A4A4A] text-[14px] md:text-[16px] leading-[1.6] font-body">Payment data handled with the security protocols financial institutions require</p>
            </div>
          </div>

          {/* In Progress Section */}
          <div class="bg-white/40 backdrop-blur-sm rounded-2xl p-6 md:p-8">
            <h3 class="text-[#1A1A1A] text-[20px] md:text-[24px] font-bold mb-3 md:mb-4 font-display">In Progress: ISO 20000 & SOC 2</h3>
            <p class="text-[#4A4A4A] text-[15px] md:text-[18px] leading-[1.7] font-body">
              We're actively working toward ISO 20000 (IT Service Management) and SOC 2 certification because our clients' industries demand it, and frankly, because it makes us better at what we do.
            </p>
          </div>

          {/* What This Means */}
          <div>
            <h3 class="text-[#1A1A1A] text-[20px] md:text-[24px] font-bold mb-3 md:mb-4 font-display">What This Actually Means for You</h3>
            <div class="space-y-3 md:space-y-4">
              <p class="text-[#4A4A4A] text-[15px] md:text-[18px] leading-[1.7] font-body">
                When you work with Defrilex, you're partnering with a multilingual BPO that understands compliance isn't just paperwork it's about protecting your business, your clients, and your reputation. These certifications mean we've built systems and processes that meet international standards for quality, security, and data protection.
              </p>
              <p class="text-[#4A4A4A] text-[15px] md:text-[18px] leading-[1.7] font-body">
                Whether you're handling sensitive patient information, processing payments, or managing confidential client data across borders, we've done the work to ensure you can trust us with it.
              </p>
              <p class="text-[#1A1A1A] text-[15px] md:text-[18px] leading-[1.7] font-bold font-body">
                No shortcuts. No exceptions. Just the level of security and quality your business deserves.
              </p>
            </div>
          </div>
        </div>

        {/* Association Logos Section */}
        <div class="mt-16 md:mt-24">
          <p class="text-[#1A1A1A] text-[18px] md:text-[20px] font-bold mb-6 md:mb-10 font-display">
            Proud Member of
          </p>
          <div class="bg-white/40 backdrop-blur-sm rounded-3xl px-4 sm:px-8 md:px-12 py-8 md:py-10 flex flex-wrap justify-center gap-6 md:gap-8 lg:gap-10">
            {certificationLogos.map((logo, index) => (
              <div 
                class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
              >
                <img 
                  src={logo.src} 
                  alt={logo.alt}
                  style={{ height: `${logo.height * 0.7}px` }}
                  class="w-auto object-contain opacity-90 hover:opacity-100 transition-opacity duration-300 md:scale-100"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>